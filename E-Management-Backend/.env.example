NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/task_management?schema=public

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7
JWT_REFRESH_EXPIRES_IN_DAYS_REMEMBER=30

# Cookies
COOKIE_SECRET=replace_with_a_long_random_string

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_CLIENT_ID=task-management-api
KAFKA_BROKERS=localhost:9092

# SMTP / Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@taskmanagement.local

# File Upload
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=src/uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Seed
SEED_ADMIN_EMAIL=admin@taskmanagement.local
SEED_ADMIN_PASSWORD=Admin@12345
