// ============================================================================
// Employee Task Management System — Prisma Schema
// Database: PostgreSQL
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  ADMIN
  EMPLOYEE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DUE_SOON
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
}

// ----------------------------------------------------------------------------
// Users — auth identity. One User has at most one Employee profile.
// ----------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  isActive     Boolean  @default(true)

  // Forgot / reset password
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  createdAt DateTime @updatedAt @default(now())
  updatedAt DateTime @updatedAt

  employee      Employee?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  notifications Notification[]
  uploadedFiles File[]

  @@index([email])
  @@map("users")
}

// ----------------------------------------------------------------------------
// Employees — profile data, 1:1 with User (a User with role EMPLOYEE always
// has a linked Employee record; ADMIN users may or may not have one).
// ----------------------------------------------------------------------------

model Employee {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  department  String
  designation String

  isDeleted   Boolean  @default(false) // soft delete
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedTasks Task[] @relation("AssignedEmployee")

  @@index([department])
  @@index([isDeleted])
  @@map("employees")
}

// ----------------------------------------------------------------------------
// Tasks
// ----------------------------------------------------------------------------

model Task {
  id          String       @id @default(uuid())
  title       String
  description String       @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)

  startDate   DateTime
  dueDate     DateTime

  assignedToId String
  assignedTo   Employee @relation("AssignedEmployee", fields: [assignedToId], references: [id])

  createdById  String

  completedAt  DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attachments   File[]
  notifications Notification[]

  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

// ----------------------------------------------------------------------------
// Files — polymorphic-lite attachment, currently only attached to Task.
// ----------------------------------------------------------------------------

model File {
  id           String   @id @default(uuid())
  originalName String
  storedName   String   @unique
  mimeType     String
  sizeBytes    Int
  path         String

  taskId       String?
  task         Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  createdAt    DateTime @default(now())

  @@index([taskId])
  @@map("files")
}

// ----------------------------------------------------------------------------
// Notifications
// ----------------------------------------------------------------------------

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId    String?
  task      Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)

  type      NotificationType
  message   String
  isRead    Boolean          @default(false)

  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ----------------------------------------------------------------------------
// Refresh Tokens — supports rotation + revocation, "Remember Me" via
// extended expiresAt, one row per issued token (hashed, never store raw).
// ----------------------------------------------------------------------------

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash   String    @unique
  rememberMe  Boolean   @default(false)

  revoked     Boolean   @default(false)
  replacedBy  String?

  userAgent   String?
  ipAddress   String?

  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ----------------------------------------------------------------------------
// Audit Logs — admin actions & auth events for traceability.
// ----------------------------------------------------------------------------

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     AuditAction
  entity     String      // e.g. "Employee", "Task", "Auth"
  entityId   String?

  metadata   Json?
  ipAddress  String?

  createdAt  DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}
